{
  "log": {
    "disabled": false,
    "level": "info",
    "timestamp": false
  },
  "dns": {
    "servers": [
      {
        "address": "https://8.8.8.8/dns-query",
        "tag": "google",
        "detour": "select"
      },
      {
        "address": "https://223.5.5.5/dns-query",
        "tag": "alidns",
        "detour": "direct"
      },
      {
        "address": "rcode://success",
        "tag": "block"
      },
      {
        "address": "fakeip",
        "tag": "fakeip"
      }
    ],
    "rules": [
      {
        "domain_suffix": [
          ".arpa.",
          ".arpa"
        ],
        "server": "block"
      },
      {
        "query_type": [
          "HTTPS",
          "SVCB"
        ],
        "server": "block"
      },
      {
        "outbound": "any",
        "server": "alidns",
        "disable_cache": true
      },
      {
        "query_type": [
          "A",
          "AAAA"
        ],
        "server": "fakeip",
        "rewrite_ttl": 1
      },
      {
        "clash_mode": "Direct",
        "server": "alidns"
      },
      {
        "clash_mode": "Global",
        "server": "fakeip"
      },
      {
        "rule_set": [
          "geosite-apple@cn",
          "geosite-category-games@cn",
          "geosite-geolocation-cn"
        ],
        "server": "alidns"
      }
    ],
    "strategy": "prefer_ipv4",
    "independent_cache": true,
    "fakeip": {
      "enabled": true,
      "inet4_range": "198.18.0.0/15",
      "inet6_range": "fc00::/18"
    }
  },
  "inbounds": [
    {
      "type": "tun",
      "inet4_address": "172.19.0.0/30",
      "inet6_address": "fdfe:dcba:9876::0/126",
      "mtu": 9000,
      "gso": true,
      "auto_route": true,
      "strict_route": true,
      "inet4_route_exclude_address": [
        "239.255.255.250/32",
        "224.0.0.167/32",
        "255.255.255.255/32"
      ],
      "endpoint_independent_nat": true,
      "stack": "system",
      "platform": {
        "http_proxy": {
          "enabled": true,
          "server": "127.0.0.1",
          "server_port": 2333
        }
      }
    },
    {
      "type": "mixed",
      "strategy": "prefer_ipv4",
      "listen": "127.0.0.1",
      "listen_port": 2333
    }
  ],
  "outbounds": [
    {
      "type": "selector",
      "tag": "select",
      "outbounds": [
        "exclude: (Traffic Reset|Expire Date|GB |直连|回国)"
      ]
    },
    {
      "type": "selector",
      "tag": "paypal us",
      "outbounds": [
        "include: (United States|US)",
        "select"
      ]
    },
    {
      "type": "dns",
      "tag": "dns-out"
    }
  ],
  "route": {
    "rules": [
      {
        "port": 53,
        "outbound": "dns-out"
      },
      {
        "port": [
          25,
          465,
          587
        ],
        "outbound": "direct"
      },
      {
        "clash_mode": "Direct",
        "outbound": "direct"
      },
      {
        "clash_mode": "Global",
        "outbound": "select"
      },
      {
        "rule_set": "geosite-apple@cn",
        "outbound": "direct"
      },
      {
        "rule_set": "geosite-category-games@cn",
        "outbound": "direct"
      },
      {
        "rule_set": "geosite-paypal",
        "outbound": "paypal us"
      },
      {
        "rule_set": "geosite-telegram",
        "outbound": "select"
      },
      {
        "rule_set": "geoip-telegram",
        "outbound": "select"
      },
      {
        "rule_set": "geosite-geolocation-!cn",
        "outbound": "select"
      },
      {
        "rule_set": "geosite-geolocation-cn",
        "outbound": "direct"
      },
      {
        "rule_set": "geoip-cn",
        "outbound": "direct"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      }
    ],
    "final": "select",
    "auto_detect_interface": true,
    "rule_set": [
      {
        "type": "remote",
        "tag": "geosite-geolocation-cn",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-geolocation-cn.srs"
      },
      {
        "type": "remote",
        "tag": "geosite-geolocation-!cn",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-geolocation-!cn.srs"
      },
      {
        "type": "remote",
        "tag": "geoip-cn",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geoip/rule-set/geoip-cn.srs"
      },
      {
        "type": "remote",
        "tag": "geosite-apple@cn",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-apple@cn.srs"
      },
      {
        "type": "remote",
        "tag": "geosite-category-games@cn",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-category-games@cn.srs"
      },
      {
        "type": "remote",
        "tag": "geosite-paypal",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-paypal.srs"
      },
      {
        "type": "remote",
        "tag": "geosite-telegram",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-telegram.srs"
      },
      {
        "type": "remote",
        "tag": "geoip-telegram",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo-lite/geoip/telegram.srs"
      }
    ]
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "store_fakeip": true
    },
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "secret": ""
    }
  }
}
